{
  "name": "game-theory-sim",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "infra:up": "docker compose -f ../docker-compose.yaml up -d",
    "infra:down": "docker compose -f ../docker-compose.yaml down",
    "infra:logs": "docker compose -f ../docker-compose.yaml logs -f",
    "infra:reset": "docker compose -f ../docker-compose.yaml down -v && docker compose -f ../docker-compose.yaml up -d",
    "infra:status": "docker compose -f ../docker-compose.yaml ps",
    "docker:build": "cd .. && TAG=$(git rev-parse --short HEAD) && docker build -t link108/game-theory-sim:$TAG -t link108/game-theory-sim:latest .",
    "docker:push": "TAG=$(git rev-parse --short HEAD) && docker push link108/game-theory-sim:$TAG && docker push link108/game-theory-sim:latest",
    "verify": "pnpm lint && pnpm typecheck && pnpm build",
    "check": "pnpm typecheck && pnpm lint",
    "setup": "pnpm install && pnpm infra:up && sleep 3 && pnpm db:generate && pnpm db:push && pnpm db:seed",
    "setup:fresh": "pnpm infra:reset && sleep 5 && pnpm db:generate && pnpm db:push && pnpm db:seed",
    "dev:full": "pnpm infra:up && pnpm dev",
    "clean": "rm -rf .next node_modules/.cache"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
