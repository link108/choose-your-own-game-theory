generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ScenarioStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum SessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum ScenarioCreationSessionStatus {
  ACTIVE
  DRAFT_READY
  ACCEPTED
  ABANDONED
}

enum ScenarioCreationMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ScenarioCreationMessageKind {
  CHAT
  SUMMARY
  OPTION_PROMPT
  DRAFT_UPDATE
}

enum ScenarioCreationOptionSelectionMode {
  SINGLE
  MULTIPLE
}

enum ScenarioCreationOptionGroupStatus {
  OPEN
  RESOLVED
  SUPERSEDED
}

model Scenario {
  id               String         @id @default(cuid())
  name             String
  description      String         @db.Text
  worldDescription String         @db.Text
  status           ScenarioStatus @default(DRAFT)
  resolverConfig   Json?
  promptConfig     Json?          // Effect descriptions, scenario context for LLM prompts
  scenarioPackage  Json?          // Validated scenario DSL package for generated mechanics
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  actors         Actor[]
  worldVariables WorldVariable[]
  sessions       GameSession[]
}

model ScenarioCreationSession {
  id                String                        @id @default(cuid())
  status            ScenarioCreationSessionStatus @default(ACTIVE)
  title             String?
  sourcePrompt      String                        @default("")
  workingDraft      Json?
  createdScenarioId String?
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  messages     ScenarioCreationMessage[]
  optionGroups ScenarioCreationOptionGroup[]

  @@index([status])
}

model ScenarioCreationMessage {
  id        String                      @id @default(cuid())
  sessionId String
  role      ScenarioCreationMessageRole
  kind      ScenarioCreationMessageKind @default(CHAT)
  content   String                      @db.Text
  metadata  Json?
  createdAt DateTime                    @default(now())

  session ScenarioCreationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model ScenarioCreationOptionGroup {
  id            String                              @id @default(cuid())
  sessionId     String
  stage         String
  kind          String
  title         String
  description   String?                             @db.Text
  selectionMode ScenarioCreationOptionSelectionMode
  status        ScenarioCreationOptionGroupStatus   @default(OPEN)
  options       Json
  createdAt     DateTime                            @default(now())
  updatedAt     DateTime                            @updatedAt

  session ScenarioCreationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
}

model Actor {
  id             String   @id @default(cuid())
  scenarioId     String
  name           String
  description    String   @db.Text
  goals          Json     @default("[]")
  traits         Json     @default("[]")
  isPlayer       Boolean  @default(false)
  responseConfig Json?    // Available effect types, resource priorities, personality hints
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  scenario          Scenario            @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  resources         ActorResource[]
  relationshipsFrom ActorRelationship[] @relation("fromActor")
  relationshipsTo   ActorRelationship[] @relation("toActor")
  actorResponses    ActorResponse[]

  @@index([scenarioId])
}

model ActorResource {
  id       String @id @default(cuid())
  actorId  String
  name     String
  value    Int
  minValue Int    @default(0)
  maxValue Int    @default(9999)

  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
}

model ActorRelationship {
  id          String  @id @default(cuid())
  fromActorId String
  toActorId   String
  type        String  @default("neutral")
  strength    Int     @default(50)
  description String? @db.Text

  fromActor Actor @relation("fromActor", fields: [fromActorId], references: [id], onDelete: Cascade)
  toActor   Actor @relation("toActor", fields: [toActorId], references: [id], onDelete: Cascade)

  @@unique([fromActorId, toActorId])
  @@index([fromActorId])
  @@index([toActorId])
}

model WorldVariable {
  id         String  @id @default(cuid())
  scenarioId String
  name       String
  value      String
  kind       String  @default("resource")
  minValue   String?
  maxValue   String?
  config     Json?

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
}

model GameSession {
  id         String        @id @default(cuid())
  scenarioId String
  turn       Int           @default(0)
  state      Json
  status     SessionStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  turns    Turn[]

  @@index([scenarioId])
}

model Turn {
  id               String   @id @default(cuid())
  sessionId        String
  turnNumber       Int
  playerChoiceId   String?
  playerChoiceText String?  @db.Text
  stateChanges     Json     @default("[]")
  events           Json     @default("[]")
  proposals        Json?    // Raw LLM proposals before resolution
  resolverLog      Json?
  createdAt        DateTime @default(now())

  session        GameSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actorResponses ActorResponse[]
  renderedPage   RenderedPage?

  @@unique([sessionId, turnNumber])
  @@index([sessionId])
}

model ActorResponse {
  id        String  @id @default(cuid())
  turnId    String
  actorId   String
  action    String  @db.Text
  reasoning String? @db.Text

  turn  Turn  @relation(fields: [turnId], references: [id], onDelete: Cascade)
  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([turnId])
  @@index([actorId])
}

model RenderedPage {
  id           String   @id @default(cuid())
  turnId       String   @unique
  title        String
  narrative    String   @db.Text
  stateSummary Json
  choices      Json     @default("[]")
  createdAt    DateTime @default(now())

  turn Turn @relation(fields: [turnId], references: [id], onDelete: Cascade)
}
