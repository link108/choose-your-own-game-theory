# Postgres (docker compose default shown)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/cyoa

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# Auth: signs bearer JWTs (generate with `openssl rand -hex 32`).
# Register/login stay disabled while this is unset.
JWT_SECRET=

# This account gets the admin role on register/login — the living-scenarios
# review UI at /admin and /api/admin/*.
ADMIN_EMAIL=
