# Postgres (docker compose default shown)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/cyoa

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# Auth: signs bearer JWTs (generate with `openssl rand -hex 32`).
# Register/login stay disabled while this is unset.
JWT_SECRET=

# This account gets the admin role on register/login — the living-scenarios
# review UI at /admin and /api/admin/*.
ADMIN_EMAIL=

# Resend (https://resend.com) for verification/reset/welcome emails.
# While unset, emails are logged (links included) instead of sent — fine for dev.
RESEND_API_KEY=
EMAIL_FROM=Scenario Sim <noreply@byah.org>
# Base URL used in links inside emails (prod: https://game-theory.byah.org)
APP_BASE_URL=http://localhost:5173
